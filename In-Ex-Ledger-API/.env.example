NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://user:password@localhost:5432/inex_ledger

# ── Database SSL ───────────────────────────────────────────────────────────────
# DB_SSL: master SSL switch.
#   "true" or "require" → enable SSL (always on in production even without this)
#   "false" or "disable" → disable SSL entirely (local dev / private networks)
# Omit in development unless your local Postgres requires SSL.
DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED: whether to verify the server's certificate chain.
#   "true"  → strict validation (required for public managed Postgres — Railway,
#              Supabase, RDS, etc.).  This is the production default.
#   "false" → accept self-signed / private-CA chains.  Set ONLY when you control
#              the Postgres server and it uses a self-signed certificate.
#              Prefer supplying DB_SSL_CA_CERT instead of disabling validation.
DB_SSL_REJECT_UNAUTHORIZED=false
# DB_SSL_CA_CERT: absolute path to a PEM CA bundle for private-CA Postgres.
# Using a CA cert is safer than setting DB_SSL_REJECT_UNAUTHORIZED=false.
# DB_SSL_CA_CERT=/run/secrets/db-ca.pem

# ── Database retry ─────────────────────────────────────────────────────────────
# How long (ms) to wait before retrying a failed DB connection at startup.
DB_RETRY_DELAY_MS=15000

# ── Authentication ─────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret
# Seconds until access token expires (default: 900 = 15 min)
JWT_EXPIRY_SECONDS=900
# Seconds until access token expires — overrides JWT_EXPIRY_SECONDS if set
ACCESS_TOKEN_EXPIRY_SECONDS=900
# Days until refresh token expires (default: 7)
REFRESH_TOKEN_EXPIRY_DAYS=7
# bcrypt cost factor (default: 12 — increase for stronger hashing at cost of speed)
BCRYPT_SALT_ROUNDS=12

# ── CSRF ───────────────────────────────────────────────────────────────────────
# Secret for HMAC-signing CSRF tokens. Falls back to JWT_SECRET if not set.
# Should be a separate long random string in production.
CSRF_SECRET=replace-with-a-long-random-csrf-secret

# ── MFA ────────────────────────────────────────────────────────────────────────
# Minutes before an emailed MFA code expires (default: 10)
MFA_EMAIL_CODE_EXPIRY_MINUTES=10
# Days a trusted device bypass remains valid (default: 30)
MFA_TRUST_EXPIRY_DAYS=30

# ── Export grants ──────────────────────────────────────────────────────────────
EXPORT_GRANT_SECRET=replace-with-a-second-long-random-secret
# Milliseconds an export grant token is valid (default: 300000 = 5 min)
EXPORT_GRANT_TTL_MS=300000
# Optional JWK public key for encrypting export payloads (leave blank to disable)
# EXPORT_PUBLIC_KEY_JWK=
# EXPORT_PUBLIC_KEY_KID=export-key-1

# ── Field encryption ───────────────────────────────────────────────────────────
# 64 hex chars (256-bit AES key) for encrypting sensitive DB fields.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production — server will refuse to start without it.
FIELD_ENCRYPTION_KEY=replace-with-64-hex-chars

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_replace_me
# Sender address shown in From header (fallback: EMAIL_FROM)
RESEND_FROM_EMAIL=InEx Ledger <no-reply@inexledger.com>
# Legacy alias for RESEND_FROM_EMAIL — used if RESEND_FROM_EMAIL is not set
EMAIL_FROM=no-reply@inexledger.com
# Optional reply-to address
# RESEND_REPLY_TO=support@inexledger.com
# EMAIL_REPLY_TO=support@inexledger.com

# ── App URLs ───────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080

# ── Billing (Stripe) ───────────────────────────────────────────────────────────
DEFAULT_TRIAL_DAYS=30
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PRICE_V1_MONTHLY=price_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_API_VERSION=2024-06-20

# ── Rate limiting ──────────────────────────────────────────────────────────────
# Must be "true" in production. Falls back to in-memory store when REDIS_URL is not set.
RATE_LIMIT_ENABLED=false
# Optional: Redis URL for distributed rate limiting across multiple instances.
# When omitted, an in-memory store is used per instance (suitable for single-instance deployments).
REDIS_URL=

# ── Receipt storage ────────────────────────────────────────────────────────────
# Set to "true" only when /app/storage/receipts is backed by a persistent volume.
# Leave as "false" in development or when using ephemeral container storage.
RECEIPT_STORAGE_PERSISTENT=false
# Override the receipts directory (defaults to <cwd>/storage/receipts)
RECEIPT_STORAGE_DIR=

# ── PDF worker ─────────────────────────────────────────────────────────────────
# URL of the PDF generation worker service (leave blank to disable PDF exports)
# PDF_WORKER_URL=http://localhost:3001
# Shared secret for authenticating requests to the PDF worker
# PDF_WORKER_SECRET=replace-with-pdf-worker-secret
# Timeout in milliseconds for PDF generation requests (default: 15000)
# PDF_WORKER_TIMEOUT_MS=15000

# ── CPA license verification ───────────────────────────────────────────────────
# Set CPA_VERIFICATION_PROVIDER=mock to skip real verification (default in dev)
CPA_VERIFICATION_PROVIDER=mock
# CPA_VERIFICATION_API_KEY=replace-with-api-key
# CPA_VERIFICATION_TIMEOUT_MS=10000
