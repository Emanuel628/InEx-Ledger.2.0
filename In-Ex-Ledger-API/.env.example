NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://user:password@localhost:5432/inex_ledger
DB_SSL_REJECT_UNAUTHORIZED=false
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY_SECONDS=900
EXPORT_GRANT_SECRET=replace-with-a-second-long-random-secret
EXPORT_GRANT_TTL_MS=300000
RESEND_API_KEY=re_replace_me
EMAIL_FROM=no-reply@example.com
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080
DEFAULT_TRIAL_DAYS=30
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PRICE_V1_MONTHLY=price_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_API_VERSION=2024-06-20
# Rate limiting — must be "true" in production. Falls back to in-memory store when REDIS_URL is not set.
RATE_LIMIT_ENABLED=false
# Optional: Redis URL for distributed rate limiting across multiple instances.
# When omitted, an in-memory store is used per instance (suitable for single-instance deployments).
REDIS_URL=
# Receipt storage — set to "true" only when /app/storage/receipts is backed by a persistent volume.
# Leave as "false" in development or when using ephemeral container storage.
RECEIPT_STORAGE_PERSISTENT=false
# Override the receipts directory (defaults to <cwd>/storage/receipts)
RECEIPT_STORAGE_DIR=
