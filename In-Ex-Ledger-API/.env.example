NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://user:password@localhost:5432/inex_ledger
# ── Database SSL ───────────────────────────────────────────────────────────────
# DB_SSL: master SSL switch.
#   "true" or "require" → enable SSL (always on in production even without this)
#   "false" or "disable" → disable SSL entirely (local dev / private networks)
# Omit in development unless your local Postgres requires SSL.
DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED: whether to verify the server's certificate chain.
#   "true"  → strict validation (required for public managed Postgres — Railway,
#              Supabase, RDS, etc.).  This is the production default.
#   "false" → accept self-signed / private-CA chains.  Set ONLY when you control
#              the Postgres server and it uses a self-signed certificate.
#              Prefer supplying DB_SSL_CA_CERT instead of disabling validation.
DB_SSL_REJECT_UNAUTHORIZED=false
# DB_SSL_CA_CERT: absolute path to a PEM CA bundle for private-CA Postgres.
# Using a CA cert is safer than setting DB_SSL_REJECT_UNAUTHORIZED=false.
# DB_SSL_CA_CERT=/run/secrets/db-ca.pem
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY_SECONDS=900
EXPORT_GRANT_SECRET=replace-with-a-second-long-random-secret
EXPORT_GRANT_TTL_MS=300000
RESEND_API_KEY=re_replace_me
EMAIL_FROM=no-reply@example.com
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080
DEFAULT_TRIAL_DAYS=30
BILLING_PAST_DUE_GRACE_DAYS=7
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PRICE_V1_MONTHLY_US=price_replace_me
STRIPE_PRICE_V1_YEARLY_US=price_replace_me
STRIPE_PRICE_V1_MONTHLY_CA=price_replace_me
STRIPE_PRICE_V1_YEARLY_CA=price_replace_me
STRIPE_PRICE_ADDITIONAL_BUSINESS_MONTHLY_US=price_replace_me
STRIPE_PRICE_ADDITIONAL_BUSINESS_YEARLY_US=price_replace_me
STRIPE_PRICE_ADDITIONAL_BUSINESS_MONTHLY_CA=price_replace_me
STRIPE_PRICE_ADDITIONAL_BUSINESS_YEARLY_CA=price_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_API_VERSION=2024-06-20
# Rate limiting — must be "true" in production. Falls back to in-memory store when REDIS_URL is not set.
RATE_LIMIT_ENABLED=false
# Optional: Redis URL for distributed rate limiting across multiple instances.
# When omitted, an in-memory store is used per instance (suitable for single-instance deployments).
REDIS_URL=
# Receipt storage — set to "true" only when /app/storage/receipts is backed by a persistent volume.
# Leave as "false" in development or when using ephemeral container storage.
RECEIPT_STORAGE_PERSISTENT=false
# Override the receipts directory (defaults to <cwd>/storage/receipts)
RECEIPT_STORAGE_DIR=

# Additional runtime configuration
# FIELD_ENCRYPTION_KEY must be the original 64-hex key for any environment
# that needs to read or write AES-GCM encrypted fields.
FIELD_ENCRYPTION_KEY=replace-with-64-hex-chars
RESEND_FROM_EMAIL=InEx Ledger <noreply@inexledger.com>
RESEND_REPLY_TO=
EMAIL_REPLY_TO=
DB_RETRY_DELAY_MS=15000
REFRESH_TOKEN_EXPIRY_DAYS=7
MFA_TRUST_EXPIRY_DAYS=30
MFA_EMAIL_CODE_EXPIRY_MINUTES=10
ACCESS_TOKEN_EXPIRY_SECONDS=900
BCRYPT_SALT_ROUNDS=12
GEOLOCATION_API_URL=https://ipapi.co/{ip}/json/
# Privacy note: IP addresses are sent to the configured geolocation provider.
# Use an internal/approved endpoint when required by policy or regulation.
GEOLOCATION_TIMEOUT_MS=3000
PDF_WORKER_URL=
PDF_WORKER_SECRET=replace-with-a-shared-worker-secret
# RSA key pair for secure Tax ID export (JWE encryption).
# Generate both values with: node scripts/generate-export-keypair.mjs
EXPORT_PUBLIC_KEY_JWK=
EXPORT_PUBLIC_KEY_KID=export-key-1
# Private key — keep secret, never commit. Required for Tax ID export decryption on the server.
EXPORT_PRIVATE_KEY_JWK=
CPA_VERIFICATION_PROVIDER=mock
CPA_VERIFICATION_API_KEY=
CPA_VERIFICATION_TIMEOUT_MS=10000
