# =============================================================
# InEx Ledger – Required Environment Variables
# Copy this file to .env and fill in the values before running.
# =============================================================

# ── Server ────────────────────────────────────────────────────
# Port the API listens on (default: 8080)
PORT=8080

# Node environment: development | production
NODE_ENV=development

# Enable Redis-backed rate limiting. Must be "true" in production.
RATE_LIMIT_ENABLED=false

# Redis connection string used for rate limiting
REDIS_URL=redis://localhost:6379

# ── Database ──────────────────────────────────────────────────
# Full PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/inex_ledger

# Set to "false" to disable SSL certificate verification (not recommended in production)
DB_SSL_REJECT_UNAUTHORIZED=true

# ── Authentication ────────────────────────────────────────────
# Strong random secret used to sign JWT tokens (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-string

# JWT token lifetime in seconds (default: 900 = 15 minutes)
JWT_EXPIRY_SECONDS=900

# Access token lifetime in seconds (default: 900 = 15 minutes)
ACCESS_TOKEN_EXPIRY_SECONDS=900

# Refresh token lifetime in days (default: 7)
REFRESH_TOKEN_EXPIRY_DAYS=7

# bcrypt salt rounds for password hashing (default: 12)
BCRYPT_SALT_ROUNDS=12

# ── MFA ───────────────────────────────────────────────────────
# Email OTP expiry in minutes (default: 10)
MFA_EMAIL_CODE_EXPIRY_MINUTES=10

# Days before MFA trust cookie expires (default: 30)
MFA_TRUST_EXPIRY_DAYS=30

# ── Export Security ───────────────────────────────────────────
# Secret used to sign one-time export grant tokens
EXPORT_GRANT_SECRET=change-me-to-a-long-random-string

# Export grant lifetime in milliseconds (default: 300000 = 5 minutes)
EXPORT_GRANT_TTL_MS=300000

# JWK JSON string for the public key used to encrypt export tax IDs
EXPORT_PUBLIC_KEY_JWK=

# Key ID for the export public key (default: export-key-1)
EXPORT_PUBLIC_KEY_KID=export-key-1

# ── Field Encryption ─────────────────────────────────────────
# 64 hex-character key for AES-256-GCM field-level encryption (run: openssl rand -hex 32)
FIELD_ENCRYPTION_KEY=

# ── Email (Resend) ────────────────────────────────────────────
# API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# "From" address for transactional emails (used by Resend)
RESEND_FROM_EMAIL=noreply@inexledger.com

# "Reply-To" address for transactional emails
RESEND_REPLY_TO=support@inexledger.com

# "From" address for transactional emails (legacy fallback)
EMAIL_FROM=noreply@inexledger.com

# "Reply-To" address for transactional emails (legacy fallback)
EMAIL_REPLY_TO=support@inexledger.com

# ── Frontend URL ──────────────────────────────────────────────
# Public URL of the frontend (used for CORS and email links)
FRONTEND_URL=https://inexledger.com

# Base URL for the application (used in email links)
APP_BASE_URL=https://inexledger.com

# ── CPA License Verification (Phase 3) ───────────────────────
# Provider to use: "mock" (default, no external calls) | "middesk" | "trulioo"
CPA_VERIFICATION_PROVIDER=mock

# API key for the chosen verification provider (required when not using "mock")
# Middesk:  https://docs.middesk.com
# Trulioo:  https://www.trulioo.com
CPA_VERIFICATION_API_KEY=

# HTTP request timeout for external verification calls in ms (default: 10000)
CPA_VERIFICATION_TIMEOUT_MS=10000

# ── Stripe (Billing) ──────────────────────────────────────────
# Secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Stripe webhook signing secret (from dashboard or Stripe CLI)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Stripe Price ID for the V1 monthly plan
STRIPE_PRICE_V1_MONTHLY=price_xxxxxxxxxxxxxxxxxxxx

# Stripe API version (default: 2024-06-20)
STRIPE_API_VERSION=2024-06-20

# ── PDF Worker ────────────────────────────────────────────────
# Base URL of the PDF export worker service
PDF_WORKER_URL=http://localhost:8081

# Shared secret for authenticating requests to the PDF worker
PDF_WORKER_SECRET=change-me-to-a-long-random-string

# PDF worker request timeout in milliseconds (default: 15000)
PDF_WORKER_TIMEOUT_MS=15000

# ── Subscription ─────────────────────────────────────────────
# Number of days for the free trial period (default: 30)
DEFAULT_TRIAL_DAYS=30

# Number of days a past-due Stripe subscription retains paid access before downgrade.
BILLING_PAST_DUE_GRACE_DAYS=7

# Receipt upload storage directory (defaults to ./storage/receipts)
RECEIPT_STORAGE_DIR=./storage/receipts

# Set to "true" only when the receipt storage directory is on confirmed persistent storage.
# On Railway this should only be true when the path is backed by a mounted volume.
RECEIPT_STORAGE_PERSISTENT=false

# ── Logging ───────────────────────────────────────────────────
# Directory for log files (optional; defaults to ./logs)
LOG_DIR=./logs
